 * Pestaña "Mantenimiento" de ConfigOpenServBus: una tarjeta con un botón por
 * cada proceso registrado en Lib\Maintenance. Al pulsar, el proceso se encola
 * en la cola de trabajos y se ejecuta en segundo plano.
 *
 * @author Alexis Serafín (Asermar) <alexis@okodex.com>
 */
#}
<div class="container-fluid">
    <div class="row">
        <div class="col">
            <p class="text-muted mt-2">{{ trans('maintenance-help') }}</p>
        </div>
    </div>
    <div class="row">
        {% for job in fsc.getMaintenanceJobs() %}
            <div class="col-sm-6 col-lg-4 mb-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        {% if job.help %}
                            <p class="card-text text-muted small">{{ trans(job.help) }}</p>
                        {% endif %}
                        <form method="post" class="mt-auto">
                            {{ formToken() }}
                            <input type="hidden" name="action" value="enqueue-job"/>
                            <input type="hidden" name="job" value="{{ job.event }}"/>
                            <input type="hidden" name="activetab" value="maintenance"/>
                            <button type="submit" class="btn btn-{{ job.color }} w-100"
                                    {% if job.confirm %}onclick="return confirm('{{ trans('are-you-sure') }}')"{% endif %}>
                                <i class="{{ job.icon }} fa-fw"></i> {{ trans(job.label) }}
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col">
                <div class="alert alert-info">{{ trans('no-data') }}</div>
            </div>
        {% endfor %}
    </div>
</div>
