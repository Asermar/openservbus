<view>
    <columns>
        <column name="id" display="none" order="100">
            <widget type="text" fieldname="idFuel_km"/>
        </column>
        <column name="driver" order="105">
            <widget type="select" fieldname="iddriver" required="true">
                <values source="drivers" fieldcode="iddriver" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="vehicle" order="110">
            <widget type="select" fieldname="idvehicle">
                <values source="vehicles" fieldcode="idvehicle" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="date" display="right" order="120">
            <widget type="date" fieldname="fecha"/>
        </column>
        <column name="hora" display="left" order="122">
            <widget type="time" fieldname="hora" required="true"/>
        </column>
        <column name="internal-fuel-dispenser" titleurl="ListFuelKm#ListFuelPump" numcolumns="6" order="124">
            <widget type="select" fieldname="idfuel_pump" icon="fa-solid fa-thumbtack" onclick="EditFuelPump">
                <values source="fuel_pumps" fieldcode="idfuel_pump" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="fuel-type" order="130">
            <widget type="select" fieldname="idfuel_type">
                <values source="fuel_types" fieldcode="idfuel_type" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="kms" display="right" order="135">
            <widget type="number" fieldname="km" decimal="0"/>
        </column>
        <column name="km-traveled" display="right" order="140">
            <widget type="number" fieldname="km_recorridos" decimal="0"/>
        </column>
        <column name="liters" display="right" order="145">
            <widget type="number" fieldname="litros" decimal="2"/>
        </column>
        <column name="consumption" display="right" order="150">
            <widget type="number" fieldname="consumo" decimal="2"/>
        </column>
        <column name="full-tank" display="center" order="160">
            <widget type="checkbox" fieldname="deposito_lleno"/>
        </column>
        <column name="active" display="center" order="170">
            <widget type="checkbox" fieldname="activo"/>
        </column>
        <column name="creation-date" display="right" order="180">
            <widget type="datetime" fieldname="fechaalta"/>
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="success" title="active-yes" fieldname="activo">1</option>
            <option color="warning" title="active-no" fieldname="activo">0</option>
        </row>
    </rows>
    <modals>
        <group name="upload-kms" title="import-kms" icon="fa-solid fa-file-import">
            <column name="file" numcolumns="12" order="100">
                <widget type="file" fieldname="kmsfile" accept=".csv,.ods,.xls,.xlsx" required="true"/>
            </column>
            <column name="template" numcolumns="12" order="110">
                <widget type="select" fieldname="template" required="true">
                    <values/>
                </widget>
            </column>
            <column name="import-mode" numcolumns="12" order="120">
                <widget type="select" fieldname="mode" translate="true" required="true">
                    <values title="default">automatic</values>
                    <values title="only-insert">insert</values>
                    <values title="only-update">update</values>
                    <values title="insert-update">insert-update</values>
                </widget>
            </column>
        </group>
    </modals>
</view>